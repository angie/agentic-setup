#!/usr/bin/env bash
# scripts/audit
#
# Shows what's stale, up to date, and available upstream but not tracked.
# Does not download or install anything.
#
# Usage:
#   scripts/audit

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(dirname "$SCRIPT_DIR")"
VENDOR_DIR="$REPO_DIR/vendor"
LOCK_FILE="$REPO_DIR/vendor.lock.yml"
PERSONAL_DIR="$REPO_DIR/personal"

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BLUE='\033[0;34m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

require_gh() {
  if ! command -v gh &>/dev/null; then
    echo "gh CLI not found. Install from https://cli.github.com" >&2
    exit 1
  fi
}

locked_commit() {
  local source="$1"
  grep -A5 "^${source}:" "$LOCK_FILE" 2>/dev/null | grep "commit:" | awk '{print $2}' | tr -d "'" | grep -v "^null$" || echo ""
}

locked_date() {
  local source="$1"
  grep -A5 "^${source}:" "$LOCK_FILE" 2>/dev/null | grep "last_synced:" | awk '{print $2}' | grep -v "^null$" || echo "never"
}

# ---------------------------------------------------------------------------
# citypaul
# ---------------------------------------------------------------------------

audit_citypaul() {
  local REPO="citypaul/.dotfiles"
  local BRANCH="main"
  local BASE_PATH="claude/.claude"

  local locked
  locked=$(locked_commit "citypaul")
  local last_synced
  last_synced=$(locked_date "citypaul")

  local latest_commit
  latest_commit=$(gh api "repos/${REPO}/commits?path=${BASE_PATH}&sha=${BRANCH}&per_page=1" \
    --jq '.[0].sha' 2>/dev/null) || {
    echo -e "  ${RED}✗${NC} Could not reach GitHub"
    return
  }
  local latest_short="${latest_commit:0:7}"

  echo -e "${BOLD}citypaul/.dotfiles${NC}"
  echo -e "  tracked path:  ${BLUE}${BASE_PATH}${NC}"
  echo -e "  last synced:   ${DIM}${last_synced}${NC}"

  if [[ -z "$locked" ]]; then
    echo -e "  status:        ${YELLOW}NEVER SYNCED${NC} — run scripts/sync"
  elif [[ "$locked" == "$latest_short" ]]; then
    echo -e "  status:        ${GREEN}UP TO DATE${NC} (${latest_short})"
  else
    # Count commits behind
    local behind
    behind=$(gh api "repos/${REPO}/compare/${locked}...${latest_short}" \
      --jq '.behind_by // .total_commits // "?"' 2>/dev/null || echo "?")
    echo -e "  status:        ${YELLOW}OUTDATED${NC} — ${locked} → ${latest_short} (~${behind} commits)"
    echo -e "  run:           ${BLUE}scripts/sync${NC}"
  fi

  # Show available skills they have that we don't track personally
  echo ""
  echo -e "  ${DIM}Skills available upstream:${NC}"
  local upstream_skills=()
  local personal_skills=()

  if [[ -d "$VENDOR_DIR/citypaul/skills" ]]; then
    while IFS= read -r -d '' d; do
      upstream_skills+=("$(basename "$d")")
    done < <(find "$VENDOR_DIR/citypaul/skills" -mindepth 1 -maxdepth 1 -type d -print0)
  fi

  if [[ -d "$PERSONAL_DIR/skills" ]]; then
    while IFS= read -r -d '' d; do
      personal_skills+=("$(basename "$d")")
    done < <(find "$PERSONAL_DIR/skills" -mindepth 1 -maxdepth 1 -type d -print0)
  fi

  for skill in "${upstream_skills[@]}"; do
    echo -e "    ${GREEN}✓${NC} ${skill}"
  done

  echo ""
  echo -e "  ${DIM}Personal skills (not from upstream):${NC}"
  for skill in "${personal_skills[@]}"; do
    echo -e "    ${BLUE}·${NC} ${skill}"
  done
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

require_gh

echo ""
echo -e "${BOLD}agentic-setup audit${NC}"
echo ""

audit_citypaul

echo ""
